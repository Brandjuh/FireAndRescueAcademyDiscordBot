# Copy to `.env` and fill in. Never commit the real file.
DISCORD_TOKEN=your-discord-bot-token
MC_EMAIL=your-missionchief-login-email
MC_PASSWORD=your-missionchief-password

# Optional: geocoding provider API key (e.g. maps.co, LocationIQ).
# Leave empty to use free OSM Nominatim. Set the matching base_url in
# config.yaml under `geocoding:`.
GEOCODER_API_KEY=
