# Copy to `.env` and fill in. Never commit the real file.
DISCORD_TOKEN=your-discord-bot-token
MC_EMAIL=your-missionchief-login-email
MC_PASSWORD=your-missionchief-password

# Geocoding provider API key — the ONLY place the key belongs (config.yaml
# just names the provider via geocoding.base_url; the key is never put there).
# Required when base_url is maps.co / LocationIQ — without it maps.co returns
# HTTP 401. Leave empty only if geocoding.base_url is free OSM Nominatim.
GEOCODER_API_KEY=
